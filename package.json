{
  "name": "michigan-devfest-2023",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "commitlint": "commitlint --edit",
    "preview": "vite preview",
    "prepare": "husky",
    "test:a11y": "npm run build && npx serve dist -p 3000 & sleep 5 && npx @axe-core/cli http://localhost:3000 --exit",
    "lint:a11y": "eslint . --ext js,jsx --config .eslintrc.a11y.cjs",
    "a11y:check": "npm run lint:a11y && npm run test:a11y",
    "a11y:check:staged": "eslint --ext js,jsx --config .eslintrc.a11y.cjs --fix",
    "audit": "npm audit --audit-level moderate"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "eslint --config .eslintrc.a11y.cjs --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "date-fns": "^2.30.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.12.0",
    "react-router-dom": "^6.17.0",
    "react-tabs": "^6.0.2"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.8.4",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react-swc": "^3.3.2",
    "autoprefixer": "^10.4.16",
    "esbuild": "^0.19.5",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "eslint-plugin-tailwindcss": "^3.13.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.0",
    "postcss": "^8.4.31",
    "prettier": "^3.0.3",
    "serve": "^14.2.1",
    "tailwindcss": "^3.3.5",
    "vite": "^4.4.5"
  }
}
